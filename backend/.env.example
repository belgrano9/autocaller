APP_MODE=dev   # dev | int

# dev — personal Gmail
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# int — Brevo SMTP
BREVO_SMTP_USER=you@yourdomain.com
BREVO_SMTP_PASSWORD=xsmtpsib-...

FROM_EMAIL=you@gmail.com
FROM_NAME=Devis Mariages
REPLY_TO_DOMAIN=mail.devismariages.fr
TEST_EMAIL=you@gmail.com  # All emails in DEV mode are redirected here
WEBHOOK_SIGNING_KEY=

# Supervisor account — can always log in via /api/auth/login, auto-provisioned
SUPERVISOR_EMAIL=admin@yourdomain.com
SUPERVISOR_PASSWORD=change-me

# Stripe — subscription billing (use TEST MODE keys in dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...        # from `stripe listen --forward-to localhost:8000/api/billing/webhook`
STRIPE_PRICE_PLUS=price_...           # recurring monthly Price ID — Plus (€9/mo)
STRIPE_PRICE_CONCIERGERIE=price_...   # recurring monthly Price ID — Conciergerie (€19/mo)
APP_BASE_URL=http://localhost:8000
